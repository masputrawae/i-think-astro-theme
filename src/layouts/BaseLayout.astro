---
import type { CollectionEntry } from 'astro:content'
import { SITE } from '../consts'

import Head from '../components/Head.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import Main from '../components/Main.astro'

type Props = CollectionEntry<'post'>['data']
const { title, pageType, description, pubDate, updatedDate, heroImage } = Astro.props
---

<!doctype html>
<html data-theme="dark" lang={SITE.langCode} class="scroll-pt-4 scroll-smooth">
  <head>
    <script>
      ;(() => {
        const prefers = window.matchMedia('(prefers-color-scheme: dark)')
        const html = document.documentElement
        const switchTheme = () => {
          const theme = prefers.matches ? 'dark' : 'light'
          html.setAttribute('data-theme', theme)
        }

        document.addEventListener('astro:page-load', () => {
          prefers.addEventListener('change', () => {
            switchTheme()
          })
          switchTheme()
        })
      })()
    </script>
    <Head
      pageTitle={title}
      pageType={pageType}
      description={description}
      pubDate={pubDate}
      updatedDate={updatedDate}
      image={heroImage}
    />
  </head>
  <body
    class:list={[
      'font-sans',
      'bg-white text-neutral-700',
      'md:bg-neutral-50 md:p-4',
      'dark:bg-neutral-800 dark:text-neutral-300',
      'dark:md:bg-neutral-900'
    ]}
  >
    <div
      class:list={[
        'mx-auto max-w-3xl rounded-xl shadow-sm/50 md:bg-neutral-50',
        'dark:md:bg-neutral-800 dark:md:shadow-sm/100'
      ]}
    >
      <Header />
      <Main>
        <slot />
      </Main>
      <Footer />
    </div>
  </body>
</html>
